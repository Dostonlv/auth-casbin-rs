  "query": "\n                SELECT \n                    n.id, \n                    n.title, \n                    n.description, \n                    n.created_at, \n                    u.id as user_id, \n                    u.full_name, \n                    u.email,\n                    u.role\n                FROM notes n \n                INNER JOIN users u ON n.user_id = u.id \n                WHERE n.id = $1\n                ",
